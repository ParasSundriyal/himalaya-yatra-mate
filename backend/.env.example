MONGODB_URI=mongodb://localhost:27017/chardhamyatra
JWT_SECRET=change_me_to_a_long_random_string
PORT=5000

# Optional: n8n webhook (legacy). Chatbot uses built-in Groq agent when LLM_* is set.
N8N_WEBHOOK_URL=

FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccount.json
OPENWEATHERMAP_API_KEY=
# OpenTripMap — POIs for dynamic itinerary (https://opentripmap.io/product)
OPENTRIPMAP_API_KEY=
ML_SERVICE_URL=http://localhost:5001

# ─── Chatbot (Groq) ─────────────────────────────────────────────────────────
# Get a key: https://console.groq.com/keys
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
LLM_API_KEY=gsk_your_groq_api_key_here
# Leave LLM_BASE_URL unset for Groq

# Optional: reduce chatbot token usage (default 20 messages = 10 turns)
# CHAT_MEMORY_MAX_MESSAGES=8
# Groq history sent per LLM call (default 2 — pilgrim queries skip LLM entirely)
# CHAT_LLM_HISTORY_MESSAGES=2

# Optional: richer chatbot web search (falls back to Wikipedia + DuckDuckGo if unset)
# FIRECRAWL_API_KEY=fc-your_key_here
# FIRECRAWL_BASE_URL=https://api.firecrawl.dev/v1/search

# Other providers (optional):
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# LLM_API_KEY=sk-...
