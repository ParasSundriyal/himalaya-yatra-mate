        "id": "HTTP_Weather",
        "name": "OpenMeteo Weather",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 4,
        "position": [
          730,
          130
        ]
      },
      {
        "parameters": {
          "mode": "runOnceForAllItems",
          "jsCode": "let lang = 'en';\ntry {\n  lang =\n    ($('Webhook').first().json?.language ||\n      $('Webhook1').first().json?.language ||\n      'en');\n} catch (e) {\n  lang = 'en';\n}\n\nconst temp = $input.first().json?.current_weather?.temperature ?? 'N/A';\n\nreturn [{\n  json: {\n    intent: 'weather',\n    reply: lang === 'hi'\n      ? `वर्तमान तापमान ${temp}°C है`\n      : `Current temperature is ${temp}°C`,\n  }\n}];"
        },
        "id": "Code_WeatherReply",
        "name": "Format Weather Reply",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          980,
          130
        ]
      },
      {
        "parameters": {
          "mode": "runOnceForAllItems",
          "jsCode": "let lang = 'en';\ntry {\n  lang =\n    ($('Webhook').first().json?.language ||\n      $('Webhook1').first().json?.language ||\n      'en');\n} catch (e) {\n  lang = 'en';\n}\n\nreturn [{\n  json: {\n    intent: 'route',\n    reply: lang === 'hi'\n      ? 'दूरी लगभग 220 किमी है और यात्रा में करीब 8 घंटे लगते हैं।'\n      : 'Distance is ~220 km and takes around 8 hours.',\n  }\n}];"
        },
