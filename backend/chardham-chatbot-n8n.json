      {
        "parameters": {
          "mode": "runOnceForAllItems",
          "jsCode": "let lang = 'en';\ntry {\n  lang =\n    ($('Webhook').first().json?.language ||\n      $('Webhook1').first().json?.language ||\n      'en');\n} catch (e) {\n  lang = 'en';\n}\n\nreturn [{\n  json: {\n    intent: 'traffic',\n    reply: lang === 'hi'\n      ? 'सड़क और मौसम की स्थिति के कारण यात्रा समय बदल सकता है।'\n      : 'Travel time may vary due to road and weather conditions.',\n  }\n}];"
